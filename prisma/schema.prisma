}

enum ClipExportFormat {
  VERTICAL_9_16
  HORIZONTAL_16_9
  SQUARE_1_1
}

enum ClipExportStatus {
  NOT_EXPORTED
  QUEUED
  EXPORTING
  COMPLETED
  FAILED
}

enum ClipExportLayoutStrategy {
  CENTER_CROP
  LEFT_FOCUS
  RIGHT_FOCUS
  FIT_BLURRED_BACKGROUND
  // SMART_CROP is reserved for future AI framing (face detection, speaker tracking).
  // Do not implement AI framing until explicitly requested.
  SMART_CROP
}

