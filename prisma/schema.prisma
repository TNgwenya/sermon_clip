  POST_READY
  GOOD_NEEDS_REVIEW
  NEEDS_EDITING
  REJECT
}

enum ClipRankingCategory {
  BEST_OVERALL
  BEST_TEACHING_CLIP
  BEST_EMOTIONAL_CLIP
  BEST_QUOTE_PUNCHLINE_CLIP
