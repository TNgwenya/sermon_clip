{
  "name": "sermon_clip",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "build": "prisma generate && next build",
    "deploy:build": "npm run prisma:deploy:safe && npm run build",
    "prisma:deploy:safe": "node scripts/prisma-safe-deploy.mjs",
    "start": "next start",
    "lint": "eslint",
    "import:sqlite-to-postgres": "node --experimental-strip-types scripts/sqlite-to-postgres-import.ts",
    "worker:posting": "node --env-file-if-exists=.env --experimental-strip-types scripts/posting-worker.ts",
    "worker:media": "node --env-file-if-exists=.env --experimental-strip-types --loader ./scripts/ts-path-loader.mjs scripts/media-worker.ts",
    "storage:migrate-sermon-folders": "node --env-file-if-exists=.env --experimental-strip-types --loader ./scripts/ts-path-loader.mjs scripts/migrate-sermon-storage-folders.ts",
    "storage:import-local-projects": "node --env-file-if-exists=.env --experimental-strip-types --loader ./scripts/ts-path-loader.mjs scripts/import-local-sermon-projects.ts",
    "youtube:oauth": "node --env-file-if-exists=.env --experimental-strip-types scripts/youtube-oauth-token.ts",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@prisma/client": "^6.19.0",
    "@tensorflow-models/coco-ssd": "^2.2.3",
    "@tensorflow/tfjs": "^4.22.0",
    "next": "16.2.9",
    "openai": "^6.43.0",
    "pdf-lib": "^1.17.1",
    "prisma": "^6.19.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.35.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
